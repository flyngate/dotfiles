#!/usr/bin/env python3

# create a passcode using the diceware word list
# source: https://theworld.com/~reinhold/diceware.html

import sys
import string
from os import path
from random import choices

CHARS = string.ascii_lowercase + string.ascii_uppercase + string.digits
GROUP_LENGTH = 6
NUMBER_OF_GROUPS = 3

def gen_group():
    return ''.join(choices(CHARS, k = GROUP_LENGTH))

if __name__ == '__main__':
    n = NUMBER_OF_GROUPS

    if len(sys.argv) > 1:
        if sys.argv[1] == '--help':
            print('Usage: create-password [number_of_groups]')
            sys.exit(0)

        n = int(sys.argv[1])

    result = '-'.join([gen_group() for _ in range(0, n)])

    print(result)
